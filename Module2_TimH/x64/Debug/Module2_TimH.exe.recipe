/* Calculator.cpp Date: May 14th, 2026 Author: Tim Harris Fixed input order, operator checks, and division by zero errors. Changed operands to double for decimal division results. Used loops and conditionals to control program flow. */ #include <iostream> #include <cctype> // for toupper using namespace std; int main() { double op1, op2; char operation; char answer = 'Y'; while (toupper(answer) == 'Y') { cout << "Enter expression (e.g. 2 + 2): " << endl; cin >> op1 >> operation >> op2; if (operation == '+') cout << op1 << " + " << op2 << " = " << op1 + op2 << endl; else if (operation == '-') cout << op1 << " - " << op2 << " = " << op1 - op2 << endl; else if (operation == '*') cout << op1 << " * " << op2 << " = " << op1 * op2 << endl; else if (operation == '/') { if (op2 == 0) cout << "Error: Division by zero is not allowed." << endl; else cout << op1 << " / " << op2 << " = " << op1 / op2 << endl; } else cout << "Invalid operator entered." << endl; cout << "Do you wish to evaluate another expression? (Y/N): " << endl; cin >> answer; } cout << "Program Finished." << endl; return 0; }